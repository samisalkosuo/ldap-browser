APP_PORT=8080
APP_AUTH_ENABLED=false
APP_AUTH_USERNAME=admin
APP_AUTH_PASSWORD=changeme
LOG_LEVEL=info

# LDAP Connection Defaults (optional)
# If set, these values will be pre-filled in the connection form
LDAP_PROTOCOL=ldap
LDAP_HOST=ldap.example.com
LDAP_PORT=389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_USERNAME=
LDAP_PASSWORD=
LDAP_BASE_DN=dc=example,dc=com
LDAP_TIMEOUT_SECONDS=10